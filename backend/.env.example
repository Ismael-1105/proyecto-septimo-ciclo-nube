# Plantilla de variables de entorno para probar las Lambdas EN LOCAL.
# Copiar a .env (no se versiona, esta en .gitignore) y completar tras el
# primer terraform apply con los outputs del entorno dev.
#
# IMPORTANTE: las credenciales de AWS (access key y secret) NUNCA van aqui ni
# en ningun archivo del repo. Se configuran con: aws configure
# En AWS desplegado este archivo no se usa: Terraform inyecta estas variables
# a cada funcion (ver infra/envs/dev/main.tf, bloque environment_variables).

# Coleccion de rostros de Rekognition (output: collection_id)
COLLECTION_ID=por-confirmar

# Tablas DynamoDB (outputs: students_table_name, access_log_table_name)
STUDENTS_TABLE=por-confirmar
ACCESS_LOG_TABLE=por-confirmar

# Buckets S3 (outputs del modulo s3 via terraform output)
ENROLLMENT_BUCKET=por-confirmar
EVIDENCE_BUCKET=por-confirmar

# Topic SNS de alertas (output: alerts_topic_arn)
ALERTS_TOPIC_ARN=por-confirmar

# Umbral de similitud facial (el informe fija el orden del 95 al 99)
SIMILARITY_THRESHOLD=95
